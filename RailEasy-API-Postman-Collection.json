                "value": "{{admin_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/schedules/{{schedule_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules", "{{schedule_id}}"]
            }
          }
        }
      ]
    }
  ],
