{
  "info": {
    "_postman_id": "raileasy-api-collection",
    "name": "RailEasy API",
    "description": "Train Ticket Booking System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\",\n  \"name\": \"John Doe\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login (Admin)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@raileasy.com\",\n  \"password\": \"password\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Login (User)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"SecurePass123\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/auth/logout",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "logout"]
            }
          }
        }
      ]
    },
    {
      "name": "Train Search",
      "item": [
        {
          "name": "Search Schedules",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/schedules?from=Chennai%20Central&to=Mumbai%20CSMT&date=2025-10-21",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules"],
              "query": [
                {
                  "key": "from",
                  "value": "Chennai Central"
                },
                {
                  "key": "to",
                  "value": "Mumbai CSMT"
                },
                {
                  "key": "date",
                  "value": "2025-10-21"
                }
              ]
            }
          }
        },
        {
          "name": "Get Booked Seats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/schedules/{{schedule_id}}/seats?class=AC_3",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules", "{{schedule_id}}", "seats"],
              "query": [
                {
                  "key": "class",
                  "value": "AC_3"
                }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Bookings",
      "item": [
        {
          "name": "Create Booking",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{user_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"scheduleId\": \"{{schedule_id}}\",\n  \"travelClass\": \"AC_3\",\n  \"seatNumbers\": [\"5A\", \"5B\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/bookings",
              "host": ["{{base_url}}"],
              "path": ["api", "bookings"]
            }
          }
        },
        {
          "name": "Get My Bookings",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/bookings/mine",
              "host": ["{{base_url}}"],
              "path": ["api", "bookings", "mine"]
            }
          }
        },
        {
          "name": "Cancel Booking",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{user_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/bookings/{{booking_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "bookings", "{{booking_id}}", "cancel"]
            }
          }
        }
      ]
    },
    {
      "name": "Admin - Trains",
      "item": [
        {
          "name": "Get All Trains",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{admin_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/trains",
              "host": ["{{base_url}}"],
              "path": ["api", "trains"]
            }
          }
        },
        {
          "name": "Create Train",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{admin_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainNumber\": \"54321\",\n  \"trainName\": \"New Express\",\n  \"seatsPerClass\": 64\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/trains",
              "host": ["{{base_url}}"],
              "path": ["api", "trains"]
            }
          }
        },
        {
          "name": "Update Train",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{admin_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainNumber\": \"54321\",\n  \"trainName\": \"Updated Express\",\n  \"seatsPerClass\": 80\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/trains/{{train_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trains", "{{train_id}}"]
            }
          }
        },
        {
          "name": "Delete Train",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "X-User-Id",
                "value": "{{admin_id}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/trains/{{train_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "trains", "{{train_id}}"]
            }
          }
        }
      ]
    },
    {
