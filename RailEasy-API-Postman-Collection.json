              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainId\": \"{{train_id}}\",\n  \"fromStation\": \"Bangalore\",\n  \"toStation\": \"Delhi\",\n  \"departureTime\": \"2025-11-01T08:00:00\",\n  \"arrivalTime\": \"2025-11-01T20:00:00\",\n  \"journeyDate\": \"2025-11-01\",\n  \"fareSleeper\": 500.00,\n  \"fareAc3\": 1350.00,\n  \"fareAc2\": 2000.00\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/schedules",
              "host": ["{{base_url}}"],
              "path": ["api", "schedules"]
            }
          }
        },
        {
          "name": "Update Schedule",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-User-Id",
                "value": "{{admin_id}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"trainId\": \"{{train_id}}\",\n  \"fromStation\": \"Bangalore\",\n  \"toStation\": \"Delhi\",\n  \"departureTime\": \"2025-11-01T08:00:00\",\n  \"arrivalTime\": \"2025-11-01T20:00:00\",\n  \"journeyDate\": \"2025-11-01\",\n  \"fareSleeper\": 600.00,\n  \"fareAc3\": 1400.00,\n  \"fareAc2\": 2100.00\n}"
            },
            "url": {
